# ── Environment separation ────────────────────────────────────
# APP_ENV: production | demo | development   (default: production)
# DEMO_MODE: true only on the dedicated public demo service. Production is NEVER
# demo even if DEMO_MODE=true is set by mistake — APP_ENV=production hard-disables it.
# In demo mode: no login required, synthetic seeded data, all mutations blocked.
# Public URLs are configured further down under "Public URLs".
APP_ENV=development
DEMO_MODE=false

# ── Database ──────────────────────────────────────────────────
# Unset → SQLite (./telemetry.db locally, /data/telemetry.db on Render disk).
# Production/customer data: point at managed Postgres — the app normalizes the
# legacy postgres:// scheme, builds the schema on a fresh database at startup,
# and switches to a pooled engine automatically.
# DATABASE_URL=postgresql://user:password@host:5432/observeagents?sslmode=require

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Anthropic (claude-opus-4, claude-sonnet-4, claude-haiku-4) ─
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Google (gemini-2.0-pro, gemini-2.0-flash, gemini-1.5-pro) ──
GOOGLE_API_KEY=your-google-api-key-here

# ── Local models via Ollama / vLLM / LM Studio ────────────────
LOCAL_LLM_URL=http://localhost:11434/v1
# Allow LOCAL_LLM_URL to point at private/loopback addresses (default true for
# on-box Ollama). Set false in cloud deployments to block SSRF to internal IPs.
LOCAL_LLM_ALLOW_PRIVATE=true

# ── Credential encryption key (Fernet, for BYOK provider keys) ───────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Set in Render dashboard (sync:false). Never commit the real value.
CREDENTIAL_ENCRYPTION_KEY=

# ── JWT signing secret (change before deploying) ──────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string-32chars

# ── Guard mode (platform default) ─────────────────────────────
# Visibility First → Governance Later. Per-team overrides are set in the dashboard.
#   observe  — evaluate + log + shadow-block ("would block"), never block
#   alert    — same as observe, plus fires alerts
#   enforce  — actually blocks on PII / policy / budget violations
GUARD_MODE=observe

# Legacy alias (still honored if GUARD_MODE is unset): closed→enforce, open→observe
# GATEWAY_FAIL_MODE=closed

# ── Fail-open reliability tuning ──────────────────────────────
GATEWAY_LLM_TIMEOUT_SECS=30       # cap a hung upstream LLM call
GATEWAY_ENFORCE_TIMEOUT_SECS=5    # cap a slow enforcement pipeline

# ── Admin seed password (first-run only, ignored if admin already exists) ─────
# Set this to a strong password of your choice BEFORE first launch.
# If you leave it unset, a strong random password is generated and printed once
# in the startup logs — capture it there. Never ship the placeholder below to prod.
# ADMIN_SEED_PASSWORD=change-me-to-a-strong-unique-password

# ── CORS allowed origin (set to your frontend URL) ────────────────────────────
# Local dev: leave blank (defaults to localhost:5173)
# The ObserveAgents public domains, the Render fallback, and localhost are ALWAYS
# allowed regardless of this value; set it only to permit ADDITIONAL origins.
FRONTEND_ORIGIN=

# ── Public URLs (centralized; override per environment, defaults are production) ─
# app.observeagents.ai is the canonical app URL; the apex redirects to the
# marketing site at www.observeagents.ai.
PUBLIC_APP_URL=https://app.observeagents.ai
PUBLIC_GATEWAY_URL=https://gateway.observeagents.ai
PUBLIC_DEMO_URL=https://demo.observeagents.ai
PUBLIC_API_URL=https://api.observeagents.ai
PUBLIC_MARKETING_URL=https://www.observeagents.ai
# Internal fallback only — keep existing Render deployments working.
RENDER_FALLBACK_URL=https://ai-asset-app.onrender.com

# ── Debug mode (enables /docs Swagger UI — never enable in production) ────────
DEBUG=false
